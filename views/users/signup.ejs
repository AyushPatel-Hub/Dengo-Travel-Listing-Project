<% layout("/layouts/boilerplate") %>
 <div class="row">
    <h1 class="col-6 offset-3 mb-3">Signup on Dengo</h1>
        <div class="col-6 offset-3">
            <form action="/signup" method="post" class="needs-validation" novalidate>
                 <div class="mb-3">
            <label for="username" class="form-label">Username</label>
        <input required name="username" class="form-control" id="username">
        <div class="valid-feedback"> Looks Good<i class="fa-regular fa-face-smile-wink"></i></div>
        <div class="invalid-feedback">Username Please <i class="fa-regular fa-face-sad-tear"></i></div>
        </div>
        <div class="mb-3">
            <label for="email" class="form-label">Email</label>
        <input required name="email" class="form-control" id="email" type="email">
        <div class="valid-feedback"> Looks Good<i class="fa-regular fa-face-smile-wink"></i></div>
        <div class="invalid-feedback">Email Please <i class="fa-regular fa-face-sad-tear"></i></div>
        </div>
        <div class="mb-3">
            <label for="password" class="form-label">Password</label>
        <input required name="password" class="form-control" id="password" type="password">
        <div class="valid-feedback"> Looks Good<i class="fa-regular fa-face-smile-wink"></i></div>
        <div class="invalid-feedback">Password Please <i class="fa-regular fa-face-sad-tear"></i></div>
        </div>
        <button class="btn btn-success">Signup</button>
            </form>
        </div>
  </div>
