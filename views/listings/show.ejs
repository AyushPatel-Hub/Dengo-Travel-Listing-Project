<% layout("/layouts/boilerplate") %>
<div class="row showcard">
   <div class="col-8 offset-2">
      <h1 class="title"><%=showData.title%></h1>
  </div>
  <div class="col-6 offset-2 card1">
<div class="card">
  <img src="<%=showData.image.url%>" class="card-img-top show-img" alt="...">
  <div class="card-body">
   <!-- <h1 class="card-text"><%=showData.title%></h1> -->
    <p class="card-text"><h5><b>Owned by</b> <%=showData.owner.username%></h5></p>
    <p class="card-text"><%= showData.discription %></p>
    <p class="card-text">&#8377;<%=showData.price.toLocaleString("en-IN")%></p>
     <p class="card-text"><%=showData.location%></p>
     <p class="card-text"><%=showData.country%></p>
     
  </div>
</div>
  
<% if(currUser && currUser._id.equals(showData.owner._id)){%>
   <div class="btns btns1 ">
      <form method="get" action="/listings/<%=showData._id%>/edit">
    <button class="btn btn-dark add-btn">Edit</button>
   </form>
   
   
      <form method="get" action="/listings/<%=showData._id%>/delete">
    <button class="btn btn-danger">Delete</button>
   </form>
   </div>
   <%}%>
   <hr>
<div class="col-12 offset-2 mb-3">
   <h3>Add Review</h3>
   <form method="POST" action="/listings/<%=showData._id%>/reviews" novalidate class="needs-validation">
      <!-- <div class="mb-3 mt-3">
         <label for="rating" class="form-label">Rating</label>
         <input type="range" min="1" max="5" id="rating" name="review[rating]">
      </div> -->
       <label for="rating" class="form-label">Rating</label>
      <fieldset class="starability-slot">
  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>
      <div class="mb-3 mt-3">
         <label for="comment" class="form-label">Comment</label>
         <textarea required id="comment" name="review[comment]"  class="form-control " cols="30" rows="5" ></textarea>
         <div class="invalid-feedback">Please Add some Comment</div>
      </div>
      <button class="btn btn-outline-dark">Submit</button>
   </form>
   <hr>
   <h4>All Reviews</h4>
   <div class="row">
   <% for(review of showData.reviews){%>
   <div class="card col-8 mb-3" style="width: 20rem;">
  <div class="card-body card-review">
    <h5 class="card-title"><%=review.username%></h5>
    <p class="card-text">
      <%=review.comment%>
   </p>
   <!-- <p class="card-text"><%=review.rating%>&#9733;</p> -->
    <p class="starability-result" data-rating="<%=review.rating%>"></p>
   <% if(currUser && showData.owner.username==(currUser.username)){%>
   <form method="post" action="/listings/<%=showData._id%>/reviews/<%=review._id%>?_method=DELETE">
   <button class="btn btn-dark btn-sm">Delete </button>
  </form>
  <%}%>
  </div>
  
  </div>
  <%}%>
</div>

</div>
    </div>  
    <div class="col-12 col-md-8 offset-md-2 mb-3">
     <div id="map" style="width: 100%; height: 400px" class="rounded-4 shadow-sm mb-3"></div>
     </div>
<!-- <script src="/js/map.js">
</script>   -->
<script>
  // 1. Initialize the map with a temporary default view (centered on India)
  const map = new maplibregl.Map({
    style: 'https://tiles.openfreemap.org/styles/liberty',
    center: [78.9629, 20.5937], 
    zoom: 4,
    container: 'map',
  });

  // 2. Get the location text from the hidden HTML input
  const locationText = "<%=showData.location%>";

  // 3. Create a function to look up coordinates automatically
  async function autoGeocodeLocation(location) {
    if (!location) return;

    try {
      // Fetch coordinates from OpenStreetMap's Nominatim engine
      const response = await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(location)}&format=geojson&limit=1`);
      const geojson = await response.json();

      if (geojson.features && geojson.features.length > 0) {
        const coordinates = geojson.features[0].geometry.coordinates; // [Longitude, Latitude]
        const displayName = geojson.features[0].properties.display_name;

        // Fly the map to the target location and zoom in
        map.flyTo({
          center: coordinates,
          zoom: 12,
          essential: true
        });

        // Drop a marker pin at the exact location
        new maplibregl.Marker()
          .setLngLat(coordinates)
          .setPopup(new maplibregl.Popup({ offset: 25 }).setHTML(`<h3>${location}</h3>`))
          .addTo(map);

      } else {
        console.log("Location not found on the map.");
      }
    } catch (error) {
      console.error("Geocoding failed:", error);
    }
  }

  // 4. Run the geocoder as soon as the map loads
  map.on('load', () => {
    autoGeocodeLocation(locationText);
  });
</script>
</div>
