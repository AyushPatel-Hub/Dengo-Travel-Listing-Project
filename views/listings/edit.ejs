<% layout("/layouts/boilerplate") %>
<div class="row">
    <div class="col-8 offset-2">
    <h2>Edit your Listing</h2>
    <p>Your Title:<%=editData.title%> </p>
    
    
    <form method="POST" action="/listings/<%=editData._id%>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
            <label for="title" class="form-label"><b>Title</b></label>
            <input required name="listing[title]" value="<%=editData.title%>" class="form-control">
    </div>
        <div class="mb-3">
            <label for="discription" class="form-label"><b>Description</b></label>
             <textarea required name="listing[discription]" rows="5" cols="20" class="form-control" value="<%=editData.discription%>"><%=editData.discription%></textarea>
        </div>
        <div>
            <img src="<%=originalUrl%>" >
        </div>
       <div class="mb-3">
        <label for="image" class="form-label"><b>New Image</b></label>
        <input name="listing[image]" class="form-control" type="file">
       </div>
        <div class="mb-3">
            <label for="price" class="form-label"><b>Price</b></label>
            <input required name="listing[price]" value="<%=editData.price%>" class="form-control" >
        </div>
        <div class="mb-3">
            <label for="location" class="form-label"><b>Location</b></label>
             <input  required name="listing[location]" value="<%=editData.location%>" class="form-control" >
        </div>
       <div class="mb-3">
         <label for="country" class="form-label"><b>Country</b></label>
         <input required name="listing[country]" value="<%=editData.country%>" class="form-control">
       </div>
        
        <button class="btn btn-dark mb-3 add-btn">Edit</button>
    </form>
    </div>
    </div>
