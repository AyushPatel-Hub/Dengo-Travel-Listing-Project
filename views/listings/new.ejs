<% layout("/layouts/boilerplate") %>

    <div class="row">
        <div class="col-8 offset-2">
       
    <h1>Add Your Listing</h1>
    
    <form method="post" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
        <input required name="listing[title]" class="form-control" placeholder="Enter title">
        <div class="valid-feedback">Title Looks Good<i class="fa-regular fa-face-smile-wink"></i></div>
        <div class="invalid-feedback">Title Please <i class="fa-regular fa-face-sad-tear"></i></div>
        </div>
        <div class="mb-3">
             <label for="discription" class="form-label">Description</label>
             <textarea required name="listing[discription]" class="form-control"></textarea>
             <div class="valid-feedback">Description<i class="fa-regular fa-face-smile-wink"></i></div>
             <div class="invalid-feedback">Description Please <i class="fa-regular fa-face-sad-tear"></i></div>
        </div>
        <!-- <div class="mb-3">
            <label for="image" class="form-label">Image URL</label>
            <input name="listing[image]" class="form-control" placeholder="Paste Image URL">
            <div class="valid-feedback"><i class="fa-regular fa-face-smile-wink"></i></div>
        </div> -->
        <div class="mb-3">
            <label for="image" class="form-label">Upload Image </label>
            <input name="listing[image]" class="form-control"  type="file" required>
            <div class="valid-feedback"><i class="fa-regular fa-face-smile-wink"></i></div>
        </div>
        <div class="mb-3">
             <label for="price" class="form-label">Price</label>
              <input required name="listing[price]" class="form-control" placeholder="Price" type="number ">
              <div class="valid-feedback">Price Looks Good<i class="fa-regular fa-face-smile-wink"></i></div>
              <div class="invalid-feedback">Price Please <i class="fa-regular fa-face-sad-tear"></i></div>
        </div>
        <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input  required name="listing[location]" class="form-control" placeholder="Location">
            <div class="valid-feedback">Location Looks Good<i class="fa-regular fa-face-smile-wink"></i></div>
            <div class="invalid-feedback">Location Please <i class="fa-regular fa-face-sad-tear"></i></div>
        </div>
       <div class="mb-3">
        <label for="country" class="form-label">Country</label>
        <input required name="listing[country]" class="form-control" placeholder="Country">
        <div class="valid-feedback">Country Looks Good<i class="fa-regular fa-face-smile-wink"></i></div>
        <div class="invalid-feedback">Country Please <i class="fa-regular fa-face-sad-tear"></i></div>
       </div>
       
        
        
        <button class="btn btn-dark mb-3 add-btn">ADD</button>
    </form>
    <br>
    <br>
    </div>
    </div>

