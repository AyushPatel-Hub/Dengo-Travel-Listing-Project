<% layout("/layouts/boilerplate") %>

  <div class="ui ">
    <div class="ui-element mt-4 mb-3"><a class="soonlinks" href="/comingsoon"><i class="fa-solid fa-fire"></i></a>
    <p>Trending</p></div>
    <div class="ui-element mt-4 mb-3 hide"><a class="soonlinks" href="/comingsoon"><i class="fa-solid fa-mountain"></i></a>
    <p>Mountains</p></div>
    <div class="ui-element mt-4 mb-3"><a class="soonlinks" href="/comingsoon"><i class="fa-solid fa-binoculars"></i></a>
    <p>Iconic cities</p></div>
    <div class="ui-element mt-4 mb-3 hide"><a class="soonlinks" href="/comingsoon"><i class="fa-solid fa-panorama"></i></a>
    <p>panorama</p></div>
    <div class="ui-element mt-4 mb-3"><a class="soonlinks" href="/comingsoon"><i class="fa-solid fa-umbrella-beach"></i></a>
    <p>Beach</p></div>
    <div class="ui-element mt-4 mb-3 hide"><a class="soonlinks" href="/comingsoon"><i class="fa-solid fa-water"></i></a>
    <p>LakeView</p></div>
    <div class="ui-element mt-4 mb-3 "><a class="soonlinks" href="/comingsoon"><i class="fa-regular fa-snowflake"></i></a>
    <p>Snowfall</p></div>
    <div class="ui-element mt-4 mb-3"><a class="soonlinks" href="/comingsoon"><i class="fa-solid fa-water-ladder"></i></a>
    <p>Pool</p></div>
    <div class="tax-toggle">
      <div class="form-check-reverse form-switch">
  <input class="form-check-input tax" type="checkbox" role="switch" id="switchCheckDefault">
  <label class="form-check-label" for="switchCheckDefault">Display Taxes</label>
</div>
    </div>
  </div>
    <h1 class="heading mb-4"></h1>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 ">
        <%for(allListing of allListings){%>
    <a href="/listings/<%=allListing._id%>" class="links"><div class="card cols" style="width: 25rem;">
  <img src="<%=allListing.image.url%>" class="card-img-top" alt="listing_image" style="height: 20rem;">
   <div class="card-img-overlay"><i class="fa-regular fa-heart"></i></div>
  <div class="card-body ">
    <p class="card-text"><b><%=allListing.title%></b></p>
    <p class="card-text">&#8377;<%=allListing.price.toLocaleString("en-IN")%>
    <i class="tax-info">+18%GST</i></p>
    <p class="card-text"><i class="fa-solid fa-map-pin"></i><%=allListing.location%>,<%=allListing.country%></p>
  </div>
</div>
</a>
 <%}%>
    </div>
 

    <!-- <ul>

            <%for(allListing of allListings){%>
                <li><a href="http://localhost:8080/listings/<%=allListing._id%>"><%=allListing.title%></a></li>
            <%}%>
    </ul> -->
<script>
  let taxswitch=document.getElementById("switchCheckDefault");
 
  taxswitch.addEventListener("click",()=>{
     let tax=document.getElementsByClassName("tax-info");
     for(info of tax){
      if(info.style.display!="inline"){
        info.style.display="inline";
      }else{
        info.style.display="none";
      }
      
     }
  })
</script>
