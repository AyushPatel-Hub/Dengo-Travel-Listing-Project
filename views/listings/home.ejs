        <div class="f-info-socials"><a href="https://github.com/AyushPatel-Hub"><i class="fa-brands fa-github"></i></a>
        <a href="https://www.instagram.com/_.clickvibes/?hl=en"><i class="fa-brands fa-square-instagram"></i></a>
        <a href="https://www.linkedin.com/in/ayushpatelcse/"><i class="fa-brands fa-linkedin"></i> </a>         
    </div>
